# Mail Trash Sorter Configuration
# Copy this to .env and fill in your values

# Email/IMAP Configuration (Required for email processing)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-email@gmail.com
IMAP_PASSWORD=your-app-password
IMAP_USE_SSL=true
IMAP_FOLDER=INBOX
IMAP_BATCH_SIZE=50

# Database Configuration
DATABASE_TYPE=sqlite
SQLITE_DB_PATH=./mailbot/data/checkpoints.db

# AWS DynamoDB (if using DynamoDB instead of SQLite)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
DYNAMODB_TABLE_NAME=mail_checkpoints

# Application Settings
LOG_LEVEL=INFO
LOG_FILE=./logs/mailbot.log

# Machine Learning Model Settings
MODEL_PATH=./mailbot/data/models/classifier.joblib
RETRAIN_THRESHOLD=100
CONFIDENCE_THRESHOLD=0.8

# Email Processing Settings
PROCESSED_FOLDER=Processed
