# Email Configuration
# IMAP settings for connecting to email server
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your.email@gmail.com
IMAP_PASSWORD=your_app_password_here

# Email processing settings
IMAP_USE_SSL=true
IMAP_FOLDER=INBOX
IMAP_BATCH_SIZE=50

# Database Configuration
# SQLite settings (local development)
DATABASE_TYPE=sqlite
SQLITE_DB_PATH=./mailbot/data/emails.db

# DynamoDB settings (production)
# DATABASE_TYPE=dynamodb
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# DYNAMODB_TABLE_NAME=mail_sorter_emails

# Application Settings
LOG_LEVEL=INFO
LOG_FILE=./logs/mailbot.log
DEBUG=false

# ML Model Configuration
MODEL_PATH=./mailbot/data/models/classifier.joblib
RETRAIN_THRESHOLD=100
CONFIDENCE_THRESHOLD=0.8

# Email Processing Rules
AUTO_DELETE_SPAM=false
SPAM_FOLDER=Spam
IMPORTANT_FOLDER=Important
PROCESSED_FOLDER=Processed
